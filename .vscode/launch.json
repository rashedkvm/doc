{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug doc (SQLite)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/doc/main.go",
      "cwd": "${workspaceFolder}",
      "env": {
        "CONFIG_FILE": "${workspaceFolder}/local.values.yml",
        "DB_DRIVER": "sqlite",
        "DB_DSN": "./doc.db",
        "IS_DEV": "true",
        "APP_PORT": "5010"
        "GHE_TOKEN": "FIX-ME"
      }
    },
    {
      "name": "Debug doc (PostgreSQL)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/doc/main.go",
      "cwd": "${workspaceFolder}",
      "env": {
        "CONFIG_FILE": "${workspaceFolder}/config/values.yml",
        "PG_USER": "postgres",
        "PG_PASS": "password",
        "PG_HOST": "127.0.0.1",
        "PG_PORT": "5432",
        "PG_DB": "doc",
        "GITTER_HOST": "127.0.0.1:1234",
        "IS_DEV": "true"
      }
    },
    {
      "name": "Debug gitter",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/gitter/main.go",
      "cwd": "${workspaceFolder}",
      "env": {
        "CONFIG_FILE": "${workspaceFolder}/config/values.yml",
        "PG_USER": "postgres",
        "PG_PASS": "password",
        "PG_HOST": "127.0.0.1",
        "PG_PORT": "5432",
        "PG_DB": "doc"
      }
    }
  ],
  "compounds": [
    {
      "name": "Debug All (gitter + doc, PostgreSQL)",
      "configurations": ["Debug gitter", "Debug doc (PostgreSQL)"]
    }
  ]
}
